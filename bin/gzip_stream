#!/usr/bin/env ruby

require "zlib"

def gzip_stream(io_in, io_out, flush_freq)
  fh = Zlib::GzipWriter.wrap(io_out)
  lock = Mutex.new
  # Zlib raises BufError if asked to flush with nothing pending
  unflushed = false
  Thread.new do
    until fh.closed?
      lock.synchronize do
        if unflushed and !fh.closed?
          fh.flush
          unflushed = false
        end
      end
      sleep flush_freq
    end
  end
  io_in.each do |line|
    lock.synchronize do
      fh.print(line)
      unflushed = true
    end
  end
  lock.synchronize do
    fh.close
  end
end

gzip_stream(STDIN, STDOUT, 1) if __FILE__ == $0
