#!/usr/bin/env ruby

require "fileutils"
require "json"
require "net/http"
require "optimist"
require "uri"

class FlickrGetter
  REST_ENDPOINT = "https://api.flickr.com/services/rest/"

  attr_reader :root_dir

  def initialize(root_dir)
    @root_dir = root_dir
  end

  def api_key
    '0309264c0827bdb4ebcbff7c5b4a14a3'
  end

  def flickr_api_call(method, params={})
    query = params.merge(
      method: method,
      api_key: api_key,
      format: "json",
      nojsoncallback: "1",
    )
    url = URI.parse(REST_ENDPOINT)
    url.query = URI.encode_www_form(query)
    response = JSON.parse(Net::HTTP.get(url))
    if response["stat"] != "ok"
      raise "Flickr API error in #{method}: #{response["message"]}"
    end
    response
  end

  # The id sits in a different place in every URL flickr ever used, and it's
  # never the last number - photo pages can be followed by /in/album-<id>/,
  # image files by a secret and a size:
  #   https://www.flickr.com/photos/naikaklutz/6752498919/
  #   https://www.flickr.com/photos/naikaklutz/6752498919/in/album-72157629178690711/
  #   https://live.staticflickr.com/7020/6752498919_066c81308f_o.jpg
  #   https://farm8.staticflickr.com/7020/6752498919_066c81308f_b.jpg
  #   http://farm8.static.flickr.com/7020/6752498919_066c81308f.jpg
  #   6752498919
  def extract_photo_id(arg)
    case arg
    when %r[\Ahttps?://(?:www\.)?flickr\.com/photos/[^/]+/(\d+)]
      $1
    when %r[\Ahttps?://(?:live|farm\d+)\.static\.?flickr\.com/\d+/(\d+)_]
      $1
    when /\A(\d+)\z/
      $1
    else
      raise "Parse error: #{arg}"
    end
  end

  # https://www.flickr.com/services/api/flickr.photos.licenses.getInfo.html
  # Codes 0-9 are the original list, 11-16 were added when flickr started
  # offering CC 4.0. Slugs for the old codes are kept as they were, so files
  # downloaded by earlier versions are still recognized as already downloaded.
  def licenses
    {
      "0"  => "non-free",
      "1"  => "cc-nc-sa",
      "2"  => "cc-nc",
      "3"  => "cc-nc-nd",
      "4"  => "cc-by",
      "5"  => "cc-sa",
      "6"  => "cc-nd",
      "7"  => "no-known-restrictions",
      "8"  => "us-government-work",
      "9"  => "public-domain",
      "10" => "public-domain-mark",
      "11" => "cc-by-4.0",
      "12" => "cc-sa-4.0",
      "13" => "cc-nd-4.0",
      "14" => "cc-nc-4.0",
      "15" => "cc-nc-sa-4.0",
      "16" => "cc-nc-nd-4.0",
    }
  end

  # photos.getInfo reports the license as a string, licenses.getInfo as a number
  def license_name(license_id)
    licenses[license_id.to_s] or raise "Unknown license #{license_id.inspect}"
  end

  def comment_from_getinfo(r)
    title      = r["photo"]["title"]["_content"]
    author     = r["photo"]["owner"]["username"]
    license    = license_name(r["photo"]["license"])
    "#{title} by #{author} from flickr (#{license.upcase})"
  end

  def filename_from_getinfo(r)
    title_fn   = r["photo"]["title"]["_content"].downcase.gsub(/ /,"_").gsub(/[^a-z0-9_]/,"")
    author_fn  = r["photo"]["owner"]["username"].downcase.gsub(/ /,"_").gsub(/[^a-z0-9_]/,"")
    license    = license_name(r["photo"]["license"])
    format     = r["photo"]["originalformat"] || "jpg"
    "#{root_dir}/#{title_fn}_by_#{author_fn}_from_flickr_#{license}.#{format}"
  end

  def url_from_getsizes(r)
    r["sizes"]["size"].max_by{|x| x["width"].to_i}["source"]
  end

  def get!(arg)
    photo_id = extract_photo_id(arg)
    r1 = flickr_api_call("flickr.photos.getInfo", :photo_id => photo_id)
    r2 = flickr_api_call("flickr.photos.getSizes", :photo_id => photo_id)

    comment  = comment_from_getinfo(r1)
    filename = filename_from_getinfo(r1)
    url      = url_from_getsizes(r2)

    if url
      if File.exist?(filename)
        puts comment
        puts "Already exists: #{filename}"
      else
        FileUtils.mkdir_p File.dirname(filename)
        system "wget", "-nv", url, "-O", filename
        puts url
        puts comment
        puts filename
      end
    else
      puts comment
      puts "Failed to get #{filename}"
    end
  end
end

def flickr_get!(args)
  opts = Optimist::options do
    opt :out, "Directory to save files to", :default => "#{ENV["HOME"]}/Downloads"
  end

  fg = FlickrGetter.new(opts[:out])

  args = STDIN.readlines.map(&:strip) if args.empty?
  args.each do |arg|
    fg.get! arg
  end
end

flickr_get!(ARGV) if __FILE__ == $0
