#!/usr/bin/env ruby
require "pathname"
require "shellwords"

def which(a)
  (ENV['PATH']||"").split(":").each do |dir|
    begin
      # realpath, as symlink targets are relative to the symlink's directory,
      # not to our cwd
      f = (Pathname(dir)+a).realpath
      return f.to_s if (f.executable? and
                        f.file? and
                        f.open{|fh| fh.read(2)} == "#!")
    rescue
    end
  end
  a
end

args = ARGV.map do |a|
  if File.exist?(a) or a =~ %r[(\A-)|/]
    a
  else
    which(a)
  end
end

# Extra variable E_EDITOR in case you want EDITOR to be 'code -w'
# (for git/svn/etc.) but you don't want -w flag passed to e
editor = ENV["E_EDITOR"] || ENV["EDITOR"] || "code"
cmd = Shellwords.split(editor) + args
exec(*cmd)
