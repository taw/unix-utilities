#!/usr/bin/env ruby

def File.namenorm(fn)
  nfn = fn.tr("A-Z '", "a-z_")
  return if fn == nfn
  if !File.exist?(nfn) or File.identical?(fn, nfn)
    File.rename(fn, nfn)
  else
    warn "Already exists, skipping: #{nfn}"
  end
end

files = ARGV
files = files[1..-1].map{|p| Dir[p]}.flatten if files[0] == '-x'
files.each{|fn| File.namenorm(fn)}
